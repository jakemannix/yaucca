# Letta server connection
LETTA_BASE_URL=http://localhost:8283
# LETTA_API_KEY=          # Only needed for Letta Cloud or authenticated servers

# yaucca agent ID (set after running: uv run python -m yaucca.setup_agent)
YAUCCA_AGENT_ID=

# Session summarization settings (all optional, defaults shown)
# YAUCCA_SUMMARY_ENABLED=true          # Toggle LLM summarization on/off
# YAUCCA_SUMMARY_MODEL=                # Model for claude -p (empty = default)
# YAUCCA_SUMMARY_MIN_EXCHANGES=3       # Exchanges threshold to trigger summary
# YAUCCA_SUMMARY_MIN_CHARS=2000        # Chars threshold to trigger summary
# YAUCCA_SUMMARY_TIMEOUT=90            # Seconds for claude -p subprocess
# YAUCCA_SUMMARY_MAX_TRANSCRIPT_CHARS=100000  # Truncation limit for transcripts
# YAUCCA_SUMMARY_CLAUDE_COMMAND=claude  # Path to claude CLI

# Only needed if Letta server requires OpenAI embeddings
# OPENAI_API_KEY=
